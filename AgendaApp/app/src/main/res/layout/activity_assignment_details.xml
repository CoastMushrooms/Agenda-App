<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/assignment_details"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/padding_medium" />

        <!-- Image Preview -->
        <LinearLayout
            android:id="@+id/imagePreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/padding_medium">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/captured_image"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/padding_small" />

            <ImageView
                android:id="@+id/capturedImagePreview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerInside"
                android:background="@color/calendar_day_background" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/assignment_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/padding_small" />

        <EditText
            android:id="@+id/assignmentTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/title_hint"
            android:inputType="text"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/edit_text_background"
            android:layout_marginBottom="@dimen/padding_medium"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <!-- Subject -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subject"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/padding_small" />

        <EditText
            android:id="@+id/assignmentSubjectInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/subject_hint"
            android:inputType="text"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/edit_text_background"
            android:layout_marginBottom="@dimen/padding_medium"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/description"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/padding_small" />

        <EditText
            android:id="@+id/assignmentDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="@string/description_hint"
            android:inputType="textMultiLine"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/edit_text_background"
            android:layout_marginBottom="@dimen/padding_medium"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:gravity="top" />

        <!-- Priority -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Priority"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/padding_small" />

        <RadioGroup
            android:id="@+id/priorityRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_medium">

            <RadioButton
                android:id="@+id/priorityNone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="None"
                android:textSize="13sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/priorityLow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Low"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/priorityMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Med"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/priorityHigh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="High"
                android:textSize="13sp" />
        </RadioGroup>

        <!-- Due Date -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/due_date"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/padding_small" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_medium">

            <TextView
                android:id="@+id/dueDateDisplay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Due: May 29, 2024"
                android:padding="@dimen/padding_medium"
                android:textColor="@color/text_primary"
                android:background="@drawable/edit_text_background"
                android:textSize="14sp" />

            <Button
                android:id="@+id/selectDateBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/change_date"
                android:layout_marginStart="@dimen/padding_small"
                style="@style/Widget.AppCompat.Button.Colored" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/padding_large"
            android:paddingBottom="32dp">

            <Button
                android:id="@+id/cancelBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/padding_small"
                android:text="@string/cancel"
                style="@style/Widget.AppCompat.Button.Borderless" />

            <Button
                android:id="@+id/saveAssignmentBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/save_assignment"
                style="@style/Widget.AppCompat.Button.Colored" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
