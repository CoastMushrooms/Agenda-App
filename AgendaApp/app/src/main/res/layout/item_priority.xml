<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/white"
    android:padding="@dimen/padding_medium"
    android:layout_marginBottom="@dimen/padding_small">

    <View
        android:id="@+id/urgencyIndicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="@dimen/padding_medium"
        android:background="@color/normal_color" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/padding_extra_small">

            <TextView
                android:id="@+id/priorityTaskTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Assignment Title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/priorityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/priorityTaskSubject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Subject"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/priorityTaskDays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due in 3 days"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/due_soon_color" />
        </LinearLayout>

        <TextView
            android:id="@+id/completionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Completed - 24h left"
            android:textSize="11sp"
            android:textColor="@color/completed_color"
            android:layout_marginTop="@dimen/padding_extra_small"
            android:visibility="gone" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/deleteBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="@string/delete_assignment"
        android:scaleType="centerInside"
        android:background="@drawable/button_background"
        android:tint="@color/white"
        android:layout_marginStart="@dimen/padding_small"
        android:layout_gravity="center_vertical" />

</LinearLayout>
